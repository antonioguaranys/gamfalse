<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>MGB Talent — Candidate Shortlist · Frederico Laranjo</title>
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=Space+Grotesk:wght@400;500;600;700;800&display=swap" rel="stylesheet">
<style>
:root{
  --color-primary:#1968AD;--color-primary-dark:#0F4D82;--color-primary-light:#3A82C4;
  --color-primary-10:rgba(25,104,173,0.10);--color-primary-15:rgba(25,104,173,0.15);
  --color-navy:#012E4D;--color-navy-dark:#001D31;--color-navy-10:rgba(1,46,77,0.10);
  --color-gold:#FAC000;--color-gold-dark:#D9A600;--color-gold-light:#FDD040;
  --color-gold-10:rgba(250,192,0,0.10);--color-gold-15:rgba(250,192,0,0.15);
  --color-green:#6A9E51;--color-green-dark:#4E7A3A;--color-green-light:#85B86A;
  --color-green-10:rgba(106,158,81,0.10);--color-green-15:rgba(106,158,81,0.15);
  --color-white:#FEFEFE;--color-error:#D63C3C;--color-error-10:rgba(214,60,60,0.10);
  --color-gray-50:#F8FAFB;--color-gray-100:#F4F6F8;--color-gray-200:#E8ECF0;
  --color-gray-300:#CDD5DF;--color-gray-400:#9AAAB8;--color-gray-500:#6B7F90;
  --color-gray-600:#445566;--color-gray-700:#2D3D4F;--color-gray-800:#1A2633;
  --font-display:'Space Grotesk',Arial,sans-serif;
  --font-body:'Inter',Arial,sans-serif;
  --shadow-sm:0 2px 8px rgba(1,46,77,0.08);--shadow-md:0 4px 16px rgba(1,46,77,0.12);--shadow-lg:0 8px 32px rgba(1,46,77,0.16);
  --radius-sm:4px;--radius-md:8px;--radius-lg:12px;--radius-xl:16px;--radius-2xl:24px;--radius-full:9999px;
  --transition-base:all 0.20s ease;--site-width:1100px;
}
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0;}
html{font-size:16px;scroll-behavior:smooth;}
body{font-family:var(--font-body);background:var(--color-gray-100);color:var(--color-gray-800);line-height:1.6;-webkit-font-smoothing:antialiased;}

/* NAV */
.nav{background:var(--color-navy);height:60px;display:flex;align-items:center;justify-content:space-between;padding:0 32px;position:sticky;top:0;z-index:100;box-shadow:var(--shadow-md);}
.nav-brand{display:flex;align-items:center;gap:12px;}
.nav-logo{width:36px;height:36px;background:var(--color-gold);border-radius:var(--radius-md);display:flex;align-items:center;justify-content:center;font-family:var(--font-display);font-weight:800;font-size:13px;color:var(--color-navy);}
.nav-title{font-family:var(--font-display);font-weight:700;font-size:16px;color:var(--color-white);}
.nav-subtitle{font-size:11px;color:rgba(255,255,255,0.45);font-weight:500;}
.nav-right{display:flex;align-items:center;gap:16px;}
.nav-badge{background:var(--color-gold);color:var(--color-navy);font-size:11px;font-weight:700;padding:4px 12px;border-radius:var(--radius-full);text-transform:uppercase;letter-spacing:0.06em;}
.nav-date{font-size:12px;color:rgba(255,255,255,0.45);}

/* PAGE */
.page{max-width:var(--site-width);margin:0 auto;padding:40px 24px 80px;}
.confidential-banner{background:var(--color-navy-10);border:1px solid var(--color-gray-200);border-radius:var(--radius-md);padding:10px 16px;display:flex;align-items:center;gap:8px;margin-bottom:24px;font-size:12px;color:var(--color-gray-600);font-weight:500;}

/* HERO */
.hero-header{background:var(--color-navy);border-radius:var(--radius-2xl);padding:40px 48px;margin-bottom:32px;position:relative;overflow:hidden;}
.hero-header::before{content:'';position:absolute;inset:0;background:radial-gradient(ellipse at 75% 50%,rgba(25,104,173,0.18) 0%,transparent 60%);pointer-events:none;}
.hero-header::after{content:'';position:absolute;top:-60px;right:-60px;width:240px;height:240px;background:radial-gradient(circle,rgba(250,192,0,0.08) 0%,transparent 70%);pointer-events:none;}
.hero-inner{position:relative;z-index:1;display:grid;grid-template-columns:1fr 1fr;gap:40px;align-items:start;}
.hero-eyebrow{font-size:11px;font-weight:700;text-transform:uppercase;letter-spacing:0.14em;color:var(--color-gold);margin-bottom:12px;display:flex;align-items:center;gap:8px;}
.hero-eyebrow::before{content:'';width:20px;height:2px;background:var(--color-gold);display:inline-block;}
.hero-name{font-family:var(--font-display);font-size:38px;font-weight:800;color:var(--color-white);line-height:1.05;margin-bottom:8px;}
.hero-title{font-family:var(--font-display);font-size:15px;font-weight:600;color:rgba(255,255,255,0.6);margin-bottom:0;line-height:1.4;}
.hero-info-grid{display:grid;grid-template-columns:1fr 1fr;gap:12px;}
.hero-info-item{background:rgba(255,255,255,0.06);border:1px solid rgba(255,255,255,0.08);border-radius:var(--radius-lg);padding:12px 16px;}
.hero-info-item.full{grid-column:span 2;}
.hero-info-label{font-size:10px;font-weight:700;text-transform:uppercase;letter-spacing:0.1em;color:rgba(255,255,255,0.35);margin-bottom:4px;}
.hero-info-value{font-family:var(--font-display);font-size:13px;font-weight:700;color:var(--color-white);line-height:1.3;}
.hero-info-value a{color:var(--color-gold-light);text-decoration:none;}
.hero-info-value a:hover{text-decoration:underline;}

/* SECTION LABEL */
.section-label{font-size:11px;font-weight:700;text-transform:uppercase;letter-spacing:0.1em;color:var(--color-gray-400);margin-bottom:16px;display:flex;align-items:center;gap:8px;}
.section-label::after{content:'';flex:1;height:1px;background:var(--color-gray-200);}

/* GRIDS */
.grid-2{display:grid;grid-template-columns:1fr 1fr;gap:20px;margin-bottom:20px;}
.grid-3{display:grid;grid-template-columns:1fr 1fr 1fr;gap:20px;margin-bottom:20px;}

/* CARD */
.card{background:var(--color-white);border-radius:var(--radius-xl);box-shadow:var(--shadow-sm);padding:24px;transition:var(--transition-base);}
.card:hover{box-shadow:var(--shadow-md);transform:translateY(-2px);}
.card-title{font-family:var(--font-display);font-size:14px;font-weight:700;color:var(--color-navy);margin-bottom:16px;display:flex;align-items:center;gap:8px;}
.card-icon{width:28px;height:28px;border-radius:var(--radius-md);display:flex;align-items:center;justify-content:center;font-size:14px;flex-shrink:0;}
.icon-blue{background:var(--color-primary-10);}
.icon-gold{background:var(--color-gold-10);}
.icon-green{background:var(--color-green-10);}
.icon-navy{background:var(--color-navy-10);}

/* PROJECTS */
.projects-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:16px;margin-bottom:32px;}
.project-card{background:var(--color-white);border-radius:var(--radius-xl);box-shadow:var(--shadow-sm);padding:20px;transition:var(--transition-base);border-top:3px solid;text-align:left;}
.project-card:hover{box-shadow:var(--shadow-md);transform:translateY(-2px);}
.project-card.top{border-top-color:var(--color-gold);}
.project-card.mid{border-top-color:var(--color-primary);}
.project-card.base{border-top-color:var(--color-green);}
.project-rank{font-size:10px;font-weight:800;text-transform:uppercase;letter-spacing:0.1em;color:var(--color-gray-400);margin-bottom:8px;}
.project-title{font-family:var(--font-display);font-size:16px;font-weight:800;color:var(--color-navy);margin-bottom:4px;line-height:1.2;}
.project-studio{font-size:12px;font-weight:600;color:var(--color-gray-500);margin-bottom:12px;}
.project-tags{display:flex;flex-wrap:wrap;gap:4px;margin-bottom:14px;}
.project-tag{background:var(--color-gray-100);border:1px solid var(--color-gray-200);border-radius:var(--radius-full);padding:2px 8px;font-size:10px;font-weight:600;color:var(--color-gray-600);text-transform:uppercase;letter-spacing:0.04em;}
.project-tag.highlight{background:var(--color-gold-10);border-color:rgba(250,192,0,0.3);color:#8A6B00;}
.project-tag.primary{background:var(--color-primary-10);border-color:rgba(25,104,173,0.2);color:var(--color-primary-dark);}
.project-tag.green{background:var(--color-green-10);border-color:rgba(106,158,81,0.2);color:var(--color-green-dark);}
.project-bullets{list-style:none;display:flex;flex-direction:column;gap:6px;}
.project-bullets li{display:flex;align-items:flex-start;gap:7px;font-size:12px;color:var(--color-gray-700);line-height:1.45;text-align:left;}
.project-bullets li::before{content:'→';color:var(--color-primary);font-weight:700;flex-shrink:0;margin-top:1px;}
.project-bullets li strong{color:var(--color-navy);font-weight:700;}

/* MATCH TABLE */
.match-table{width:100%;border-collapse:collapse;}
.match-table thead tr{border-bottom:2px solid var(--color-gray-200);}
.match-table thead th{font-size:11px;font-weight:700;text-transform:uppercase;letter-spacing:0.08em;color:var(--color-gray-400);padding:0 12px 10px;text-align:left;}
.match-table thead th:first-child{padding-left:0;}
.match-table thead th:last-child{text-align:center;}
.match-table tbody tr{border-bottom:1px solid var(--color-gray-200);transition:var(--transition-base);}
.match-table tbody tr:last-child{border-bottom:none;}
.match-table tbody tr:hover{background:var(--color-gray-50);}
.match-table tbody td{padding:12px;font-size:13px;color:var(--color-gray-700);vertical-align:top;}
.match-table tbody td:first-child{padding-left:0;font-weight:600;color:var(--color-navy);font-size:12px;}
.match-table tbody td.req{color:var(--color-gray-600);font-size:12px;}
.match-table tbody td.cand{font-size:12px;color:var(--color-gray-700);}
.match-table tbody td.score-cell{text-align:center;}
.match-badge{display:inline-flex;align-items:center;gap:4px;padding:3px 10px;border-radius:var(--radius-full);font-size:11px;font-weight:700;text-transform:uppercase;letter-spacing:0.04em;}
.badge-exceptional{background:var(--color-green-10);color:var(--color-green-dark);border:1px solid rgba(106,158,81,0.25);}
.badge-strong{background:var(--color-green-10);color:var(--color-green-dark);border:1px solid rgba(106,158,81,0.2);}
.badge-meets{background:var(--color-primary-10);color:var(--color-primary-dark);border:1px solid rgba(25,104,173,0.2);}
.badge-limited{background:var(--color-gray-100);color:var(--color-gray-600);border:1px solid var(--color-gray-300);}

/* TIMELINE */
.timeline-h-wrap{overflow-x:auto;padding-bottom:8px;}
.timeline-h{display:flex;align-items:flex-start;min-width:max-content;padding:8px 0 16px;}
.tl-item{display:flex;flex-direction:column;align-items:center;min-width:175px;max-width:200px;}
.tl-card{background:var(--color-white);border-radius:var(--radius-lg);box-shadow:var(--shadow-sm);padding:13px;width:100%;text-align:left;border-top:3px solid;}
.tl-card.gold{border-top-color:var(--color-gold);}
.tl-card.primary{border-top-color:var(--color-primary);}
.tl-card.green{border-top-color:var(--color-green);}
.tl-card.navy{border-top-color:var(--color-navy);}
.tl-card.gray{border-top-color:var(--color-gray-300);}
.tl-period{font-size:10px;font-weight:700;text-transform:uppercase;letter-spacing:0.07em;color:var(--color-gray-400);margin-bottom:3px;}
.tl-company{font-family:var(--font-display);font-size:12px;font-weight:700;color:var(--color-navy);margin-bottom:2px;line-height:1.2;}
.tl-role{font-size:11px;color:var(--color-gray-600);margin-bottom:5px;line-height:1.3;}
.tl-duration{font-size:10px;font-weight:700;color:var(--color-primary);}
.tl-chips{display:flex;flex-wrap:wrap;gap:3px;margin-top:5px;}
.tl-chip{background:var(--color-gray-100);border-radius:var(--radius-sm);padding:1px 6px;font-size:9px;font-weight:600;color:var(--color-gray-600);text-transform:uppercase;letter-spacing:0.04em;}
.tl-chip.blue{background:var(--color-primary-10);color:var(--color-primary-dark);}
.tl-chip.green{background:var(--color-green-10);color:var(--color-green-dark);}
.tl-chip.gold{background:var(--color-gold-10);color:#8A6B00;}
.tl-line{height:2px;background:var(--color-gray-200);flex:1;align-self:center;min-width:16px;}

/* SKILLS ASSESSMENT — bar-based with evidence */
.skill-row{display:flex;flex-direction:column;gap:4px;margin-bottom:18px;}
.skill-row:last-child{margin-bottom:0;}
.skill-row-header{display:flex;justify-content:space-between;align-items:center;}
.skill-row-name{font-size:12px;font-weight:700;color:var(--color-navy);}
.skill-row-score{font-family:var(--font-display);font-size:12px;font-weight:700;color:var(--color-navy);}
.skill-bar-wrap{height:7px;background:var(--color-gray-200);border-radius:var(--radius-full);overflow:hidden;}
.skill-bar-fill{height:100%;border-radius:var(--radius-full);}
.fill-gold{background:var(--color-gold);}
.fill-green{background:var(--color-green);}
.fill-primary{background:var(--color-primary);}
.fill-navy{background:var(--color-navy);}
.skill-evidence{font-size:11px;color:var(--color-gray-500);line-height:1.5;margin-top:3px;padding-left:2px;}

/* MOTIVATORS */
.motivator-grid{display:grid;grid-template-columns:1fr 1fr;gap:10px;}
.motivator-card{background:var(--color-gray-50);border:1px solid var(--color-gray-200);border-radius:var(--radius-lg);padding:14px;transition:var(--transition-base);}
.motivator-card:hover{background:var(--color-primary-10);border-color:rgba(25,104,173,0.2);}
.motivator-icon{font-size:22px;margin-bottom:6px;}
.motivator-title{font-size:12px;font-weight:700;color:var(--color-navy);margin-bottom:2px;}
.motivator-desc{font-size:11px;color:var(--color-gray-500);line-height:1.4;}

/* SALARY */
.salary-card{background:linear-gradient(135deg,var(--color-primary) 0%,var(--color-navy) 100%);border-radius:var(--radius-xl);padding:24px;color:white;}
.salary-range{font-family:var(--font-display);font-size:22px;font-weight:800;color:var(--color-gold);margin-bottom:4px;}
.salary-unit{font-size:12px;font-weight:600;color:rgba(255,255,255,0.6);margin-bottom:16px;}
.salary-row{display:flex;justify-content:space-between;align-items:center;padding:10px 0;border-bottom:1px solid rgba(255,255,255,0.1);}
.salary-row:last-child{border-bottom:none;}
.salary-row-label{font-size:12px;font-weight:600;color:rgba(255,255,255,0.6);}
.salary-row-value{font-size:13px;font-weight:700;color:var(--color-white);}
.salary-row-value.green{color:#9AC47C;}

/* REFERRALS */
.referrals-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:16px;margin-bottom:32px;}
.referral-card{background:var(--color-white);border-radius:var(--radius-xl);box-shadow:var(--shadow-sm);padding:20px;transition:var(--transition-base);display:flex;flex-direction:column;gap:12px;}
.referral-card:hover{box-shadow:var(--shadow-md);transform:translateY(-2px);}
.referral-header{display:flex;align-items:center;gap:12px;}
.referral-photo{width:48px;height:48px;border-radius:50%;object-fit:cover;flex-shrink:0;border:2px solid var(--color-gray-200);}
.referral-name{font-family:var(--font-display);font-size:14px;font-weight:700;color:var(--color-navy);line-height:1.2;}
.referral-role{font-size:11px;color:var(--color-gray-500);line-height:1.4;margin-top:2px;}
.referral-period{font-size:10px;font-weight:700;text-transform:uppercase;letter-spacing:0.06em;color:var(--color-primary);margin-bottom:2px;}
.referral-quote{font-size:12px;color:var(--color-gray-700);line-height:1.6;flex:1;font-style:italic;position:relative;padding-left:16px;}
.referral-quote::before{content:'\"';position:absolute;left:0;top:-4px;font-size:28px;color:var(--color-gold);font-style:normal;line-height:1;}
.referral-link{font-size:11px;font-weight:700;color:var(--color-primary);text-decoration:none;display:inline-flex;align-items:center;gap:4px;}
.referral-link:hover{text-decoration:underline;}
.referral-card.featured{border:2px solid var(--color-primary);box-shadow:0 4px 20px rgba(25,104,173,0.12);}
.referral-card.featured .referral-name{color:var(--color-primary-dark);}
#hidden-referrals{display:none;}
#hidden-referrals.visible{display:contents;}
.btn-view-more{background:transparent;border:2px solid var(--color-primary);color:var(--color-primary);border-radius:var(--radius-full);padding:10px 24px;font-family:var(--font-body);font-size:13px;font-weight:600;cursor:pointer;transition:var(--transition-base);display:inline-flex;align-items:center;gap:8px;margin-top:16px;}
.btn-view-more:hover{background:var(--color-primary-10);}

/* RECRUITER */
.recruiter-card{background:var(--color-navy);border-radius:var(--radius-xl);padding:28px;position:relative;overflow:hidden;margin-bottom:20px;}
.recruiter-card::before{content:'';position:absolute;top:-40px;right:-40px;width:160px;height:160px;background:radial-gradient(circle,rgba(25,104,173,0.2) 0%,transparent 70%);pointer-events:none;}
.recruiter-label{font-size:11px;font-weight:700;text-transform:uppercase;letter-spacing:0.1em;color:var(--color-gold);margin-bottom:10px;}
.recruiter-title{font-family:var(--font-display);font-size:18px;font-weight:800;color:var(--color-white);margin-bottom:16px;line-height:1.2;}
.recruiter-body{font-size:13px;color:rgba(255,255,255,0.7);line-height:1.7;margin-bottom:20px;}
.recruiter-points{display:flex;flex-direction:column;gap:10px;}
.recruiter-point{display:flex;align-items:flex-start;gap:10px;padding:12px 16px;background:rgba(255,255,255,0.06);border-left:3px solid var(--color-primary-light);border-radius:0 var(--radius-md) var(--radius-md) 0;}
.recruiter-point.warn{border-left-color:var(--color-gold);}
.recruiter-point-icon{font-size:16px;flex-shrink:0;margin-top:1px;}
.recruiter-point-text{font-size:12px;color:rgba(255,255,255,0.75);line-height:1.5;}
.recruiter-point-text strong{color:var(--color-white);font-weight:600;}

/* CTA */
.cta-strip{background:var(--color-gold);border-radius:var(--radius-xl);padding:24px 32px;display:flex;align-items:center;justify-content:space-between;gap:20px;margin-top:32px;flex-wrap:wrap;}
.cta-heading{font-family:var(--font-display);font-size:20px;font-weight:800;color:var(--color-navy);}
.cta-actions{display:flex;gap:12px;align-items:center;}
.btn-primary{background:var(--color-navy);color:var(--color-white);border:none;border-radius:var(--radius-full);padding:12px 24px;font-family:var(--font-body);font-size:13px;font-weight:600;cursor:pointer;transition:var(--transition-base);text-decoration:none;display:inline-flex;align-items:center;gap:8px;}
.btn-primary:hover{transform:translateY(-1px);box-shadow:var(--shadow-md);}
.btn-outlined{background:transparent;color:var(--color-navy);border:2px solid var(--color-navy);border-radius:var(--radius-full);padding:11px 24px;font-family:var(--font-body);font-size:13px;font-weight:600;cursor:pointer;transition:var(--transition-base);text-decoration:none;display:inline-flex;align-items:center;gap:8px;}
.btn-outlined:hover{background:rgba(1,46,77,0.06);transform:translateY(-1px);}

/* FOOTER */
.footer{margin-top:64px;padding:24px 0;border-top:1px solid var(--color-gray-200);display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:12px;}
.footer-brand{display:flex;align-items:center;gap:10px;}
.footer-logo{width:28px;height:28px;background:var(--color-navy);border-radius:var(--radius-md);display:flex;align-items:center;justify-content:center;font-family:var(--font-display);font-weight:800;font-size:11px;color:var(--color-gold);}
.footer-text{font-size:12px;font-weight:600;color:var(--color-gray-500);}
.footer-right{font-size:11px;color:var(--color-gray-400);}

@media(max-width:900px){
  .hero-inner{grid-template-columns:1fr;}
  .projects-grid,.referrals-grid{grid-template-columns:1fr 1fr;}
  .grid-2{grid-template-columns:1fr;}
  .hero-name{font-size:28px;}
  .hero-header{padding:28px 24px;}
}
@media(max-width:600px){
  .projects-grid,.referrals-grid{grid-template-columns:1fr;}
}
</style>
</head>
<body>

<nav class="nav">
  <div class="nav-brand">
    <div class="nav-logo">MGB</div>
    <div><div class="nav-title">MGB Talent</div><div class="nav-subtitle">Candidate Shortlist · Confidential</div></div>
  </div>
  <div class="nav-right">
    <div class="nav-badge">Gamebreaking Studios</div>
    <div class="nav-date">May 2026</div>
  </div>
</nav>

<div class="page">
<div class="confidential-banner">
  <span>🔒</span> This document is confidential and intended exclusively for Gamebreaking Studios. Candidate information should not be shared outside the hiring team.
</div>

<!-- HERO -->
<div class="hero-header">
  <div class="hero-inner">
    <div class="hero-left">
      <div class="hero-eyebrow">Senior Backend Engineer</div>
      <div class="hero-name">Frederico Laranjo</div>
      <div class="hero-title">Senior Backend Engineer · Post-Grad Professor</div>
    </div>
    <div class="hero-right">
